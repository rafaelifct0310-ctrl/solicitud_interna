<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- 1. VISTA DE LISTA (Odoo 19 usa <list>) -->
    <record id="view_solicitud_list" model="ir.ui.view">
        <field name="name">solicitud.interna.list</field>
        <field name="model">solicitud.interna</field>
        <field name="arch" type="xml">
            <list string="Solicitudes" decoration-success="estado=='completada'" decoration-warning="estado=='en_proceso'" decoration-info="estado=='enviada'">
                <field name="name"/>
                <field name="tipo"/>
                <field name="solicitante_id"/>
                <field name="fecha_solicitud"/>
                <field name="prioridad"/>
                <field name="estado" widget="badge" decoration-success="estado == 'completada'" decoration-info="estado == 'enviada'"/>
            </list>
        </field>
    </record>

    <!-- 2. VISTA DE BÚSQUEDA (Debe estar antes de las acciones) -->
    <record id="view_solicitud_search" model="ir.ui.view">
        <field name="name">solicitud.interna.search</field>
        <field name="model">solicitud.interna</field>
        <field name="arch" type="xml">
            <search string="Buscar Solicitudes">
                <field name="name"/>
                <field name="solicitante_id"/>
                <field name="tipo"/>
                <group expand="0" string="Agrupar por">
                    <filter string="Tipo" name="grupo_tipo" context="{'group_by': 'tipo'}"/>
                    <filter string="Estado" name="grupo_estado" context="{'group_by': 'estado'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- 3. ACCIÓN PRINCIPAL (Asegurando la referencia al search) -->
    <record id="action_solicitud" model="ir.actions.act_window">
        <field name="name">Todas las Solicitudes</field>
        <field name="res_model">solicitud.interna</field>
        <field name="view_mode">list,form,kanban</field>
        <field name="search_view_id" ref="view_solicitud_search"/>
        <field name="context">{'search_default_grupo_estado': 1}</field>
    </record>

    <!-- 4. VISTA KANBAN (Simplificada para evitar errores de renderizado) -->
    <record id="view_solicitud_kanban" model="ir.ui.view">
        <field name="name">solicitud.interna.kanban</field>
        <field name="model">solicitud.interna</field>
        <field name="arch" type="xml">
            <kanban default_group_by="estado">
                <field name="name"/>
                <field name="estado"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title"><field name="name"/></strong>
                                <div><field name="tipo"/></div>
                                <div>Prioridad: <field name="prioridad"/></div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- VISTA FORMULARIO (Sin cambios críticos, solo cierre de etiquetas) -->
    <record id="view_solicitud_form" model="ir.ui.view">
        <field name="name">solicitud.interna.form</field>
        <field name="model">solicitud.interna</field>
        <field name="arch" type="xml">
            <form string="Solicitud Interna">
                <header>
                    <button name="action_enviar" string="Enviar" type="object" invisible="estado != 'borrador'" class="oe_highlight"/>
                    <button name="action_aprobar" string="Aprobar" type="object" invisible="estado != 'enviada'" class="oe_highlight"/>
                    <button name="action_procesar" string="Procesar" type="object" invisible="estado != 'aprobada'" class="oe_highlight"/>
                    <button name="action_completar" string="Completar" type="object" invisible="estado != 'en_proceso'" class="oe_highlight"/>
                    <button name="action_cancelar" string="Cancelar" type="object" invisible="estado not in ('borrador','enviada','aprobada')"/>
                    <field name="estado" widget="statusbar" statusbar_visible="borrador,enviada,aprobada,en_proceso,completada"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="tipo"/>
                            <field name="solicitante_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="prioridad"/>
                        </group>
                    </group>
                    <group>
                        <field name="descripcion"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
