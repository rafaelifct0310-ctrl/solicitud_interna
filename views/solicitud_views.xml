<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_solicitud_list" model="ir.ui.view">
        <field name="name">solicitud.interna.list</field>
        <field name="model">solicitud.interna</field>
        <field name="arch" type="xml">
            <list string="Solicitudes" decoration-success="estado=='completada'" decoration-warning="estado=='en_proceso'" decoration-info="estado=='enviada'">
                <field name="name"/>
                <field name="tipo"/>
                <field name="solicitante_id"/>
                <field name="fecha_solicitud"/>
                <field name="prioridad"/>
                <field name="estado"/>
            </list>
        </field>
    </record>

    <record id="view_solicitud_form" model="ir.ui.view">
        <field name="name">solicitud.interna.form</field>
        <field name="model">solicitud.interna</field>
        <field name="arch" type="xml">
            <form string="Solicitud Interna">
                <header>
                    <button name="action_enviar" string="Enviar" type="object" invisible="estado != 'borrador'" class="oe_highlight"/>
                    <button name="action_aprobar" string="Aprobar" type="object" invisible="estado != 'enviada'" class="oe_highlight"/>
                    <button name="action_procesar" string="Procesar" type="object" invisible="estado != 'aprobada'" class="oe_highlight"/>
                    <button name="action_completar" string="Completar" type="object" invisible="estado != 'en_proceso'" class="oe_highlight"/>
                    <button name="action_cancelar" string="Cancelar" type="object" invisible="estado not in ('borrador','enviada','aprobada')"/>
                    <button name="action_borrador" string="Regresar a Borrador" type="object" invisible="estado != 'cancelada'"/>
                    <field name="estado" widget="statusbar" statusbar_visible="borrador,enviada,aprobada,en_proceso,completada"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="tipo"/>
                            <field name="solicitante_id" readonly="1"/>
                            <field name="fecha_solicitud" readonly="1"/>
                        </group>
                        <group>
                            <field name="prioridad"/>
                            <field name="estado" readonly="1"/>
                        </group>
                    </group>
                    <group string="Descripción">
                        <field name="descripcion" nolabel="1" placeholder="Describe tu solicitud..."/>
                    </group>
                    <group string="Respuesta" invisible="estado == 'borrador'">
                        <field name="respuesta" nolabel="1"/>
                        <field name="fecha_respuesta" readonly="1"/>
                        <field name="usuario_respuesta_id" readonly="1"/>
                    </group>
                    <group string="Aprobación" invisible="estado in ('borrador','enviada')">
                        <field name="aprobador_id" readonly="1"/>
                        <field name="fecha_aprobacion" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_solicitud_kanban" model="ir.ui.view">
        <field name="name">solicitud.interna.kanban</field>
        <field name="model">solicitud.interna</field>
        <field name="arch" type="xml">
            <kanban default_group_by="estado" class="o_kanban_mobile">
                <field name="estado"/>
                <field name="tipo"/>
                <field name="prioridad"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_card oe_kanban_global_click #{record.estado.raw_value == 'completada' ? 'o_success' : ''}">
                            <div class="o_kanban_header">
                                <field name="name"/>
                                <strong class="o_kanban_record_title" t-esc="record.name.value"/>
                            </div>
                            <div class="o_kanban_body">
                                <div t-if="record.tipo.raw_value"><i class="fa fa-tag"/> <t t-esc="record.tipo.raw_value"/></div>
                                <div t-if="record.prioridad.raw_value"><i class="fa fa-exclamation-triangle"/> <t t-esc="record.prioridad.raw_value"/></div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_solicitud_search" model="ir.ui.view">
        <field name="name">solicitud.interna.search</field>
        <field name="model">solicitud.interna</field>
        <field name="arch" type="xml">
            <search string="Buscar Solicitudes">
                <field name="name"/>
                <field name="solicitante_id"/>
                <field name="tipo"/>
                <group expand="0" string="Agrupar por">
                    <filter string="Tipo" name="grupo_tipo" context="{'group_by': 'tipo'}"/>
                    <filter string="Estado" name="grupo_estado" context="{'group_by': 'estado'}"/>
                    <filter string="Prioridad" name="grupo_prioridad" context="{'group_by': 'prioridad'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_solicitud" model="ir.actions.act_window">
        <field name="name">Todas las Solicitudes</field>
        <field name="res_model">solicitud.interna</field>
        <field name="view_mode">tree,form,kanban</field>
        <field name="context">{'search_default_grupo_estado': 1}</field>
    </record>

    <record id="action_solicitud_it" model="ir.actions.act_window">
        <field name="name">Solicitudes IT</field>
        <field name="res_model">solicitud.interna</field>
        <field name="view_mode">tree,form,kanban</field>
        <field name="domain">[('tipo', '=', 'it')]</field>
        <field name="context">{'search_default_grupo_estado': 1}</field>
    </record>

    <record id="action_solicitud_rrhh" model="ir.actions.act_window">
        <field name="name">Solicitudes RRHH</field>
        <field name="res_model">solicitud.interna</field>
        <field name="view_mode">tree,form,kanban</field>
        <field name="domain">[('tipo', '=', 'rrhh')]</field>
        <field name="context">{'search_default_grupo_estado': 1}</field>
    </record>

    <record id="action_solicitud_compras" model="ir.actions.act_window">
        <field name="name">Solicitudes Compras</field>
        <field name="res_model">solicitud.interna</field>
        <field name="view_mode">tree,form,kanban</field>
        <field name="domain">[('tipo', '=', 'compras')]</field>
        <field name="context">{'search_default_grupo_estado': 1}</field>
    </record>
</odoo>