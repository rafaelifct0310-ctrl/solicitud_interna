<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- 1. VISTA DE BÚSQUEDA (Siempre primero) -->
    <record id="view_solicitud_interna_search" model="ir.ui.view">
        <field name="name">solicitud.interna.search</field>
        <field name="model">solicitud.interna</field>
        <field name="type">search</field>
        <field name="arch" type="xml">
            <search string="Buscar Solicitudes">
                <field name="name"/>
                <field name="solicitante_id"/>
                <field name="tipo"/>
                <filter string="Mis Solicitudes" name="my_requests" domain="[('solicitante_id', '=', uid)]"/>
                <group expand="0" string="Agrupar por">
                    <filter string="Tipo" name="grupo_tipo" context="{'group_by': 'tipo'}"/>
                    <filter string="Estado" name="grupo_estado" context="{'group_by': 'estado'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- 2. VISTA DE LISTA -->
    <record id="view_solicitud_interna_list" model="ir.ui.view">
        <field name="name">solicitud.interna.list</field>
        <field name="model">solicitud.interna</field>
        <field name="arch" type="xml">
            <list string="Solicitudes" decoration-info="estado=='enviada'" decoration-success="estado=='completada'">
                <field name="name"/>
                <field name="solicitante_id" widget="many2one_avatar_user"/>
                <field name="tipo"/>
                <field name="fecha_solicitud"/>
                <field name="estado" widget="badge"/>
            </list>
        </field>
    </record>

    <!-- 3. VISTA DE FORMULARIO -->
    <record id="view_solicitud_interna_form" model="ir.ui.view">
        <field name="name">solicitud.interna.form</field>
        <field name="model">solicitud.interna</field>
        <field name="arch" type="xml">
            <form string="Solicitud Interna">
                <header>
                    <button name="action_enviar" string="Enviar" type="object" invisible="estado != 'borrador'" class="oe_highlight"/>
                    <button name="action_aprobar" string="Aprobar" type="object" invisible="estado != 'enviada'" class="oe_highlight"/>
                    <button name="action_completar" string="Completar" type="object" invisible="estado != 'en_proceso'" class="oe_highlight"/>
                    <field name="estado" widget="statusbar" statusbar_visible="borrador,enviada,aprobada,en_proceso,completada"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="solicitante_id" readonly="1"/>
                            <field name="tipo"/>
                        </group>
                        <group>
                            <field name="fecha_solicitud" readonly="1"/>
                            <field name="prioridad"/>
                        </group>
                    </group>
                    <group>
                        <field name="descripcion"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- 4. ACCIÓN -->
    <record id="action_solicitud_interna" model="ir.actions.act_window">
        <field name="name">Solicitudes Internas</field>
        <field name="res_model">solicitud.interna</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_solicitud_interna_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Crea tu primera solicitud interna</p>
        </field>
    </record>
</odoo>
